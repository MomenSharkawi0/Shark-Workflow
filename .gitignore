# =============================================================================
# Workflow runtime state (project-specific, generated at runtime).
#
# IMPORTANT: anchor these to the repo root with a leading slash. On Windows
# git defaults to core.ignorecase=true, so a bare `WORKFLOW/` would silently
# also match `roo-code-fork/src/workflow/` — which is the entire integration
# layer. Same for `plans/` (we have a docs/plans dir intent and the runtime
# `plans/` only at the root).
# =============================================================================
/WORKFLOW/
/plans/
*.log
*.lock

# =============================================================================
# Node / build artifacts (NOTE: do NOT use a bare `**/build/` — it would
# eat the legitimate workspace package `roo-code-fork/packages/build/`)
# =============================================================================
**/node_modules/
**/.turbo/
**/.next/
**/dist/
**/out/
**/.cache/
**/coverage/
**/*.tsbuildinfo

# =============================================================================
# VS Code extension build outputs (rebuild with `pnpm install:vsix` in fork)
# =============================================================================
roo-code-fork/bin/
roo-code-fork/releases/
roo-code-fork/src/dist/
roo-code-fork/webview-ui/build/
roo-code-fork/webview-ui/dist/
roo-code-fork/apps/*/dist/
roo-code-fork/apps/*/.next/
roo-code-fork/apps/vscode-nightly/build/
roo-code-fork/apps/vscode-e2e/build/
roo-code-fork/apps/web-roo-code/build/
roo-code-fork/apps/web-evals/build/
# packages/build/ is a workspace package — DO NOT exclude it.
# packages/*/dist/ is a build output — exclude it.
roo-code-fork/packages/*/dist/
*.vsix

# Roo Code's own progress/state file (generated)
roo-code-fork/progress.txt

# =============================================================================
# Editor / OS noise
# =============================================================================
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/launch.json
.vscode/.history/

# =============================================================================
# Secrets / local env
# =============================================================================
.env
.env.local
.env.*.local
*.pem
*.key

# =============================================================================
# Claude Code session state (project-specific)
# =============================================================================
.claude/
memory/
